[Unit]
Description=ATSocy on-chain price snapshot fetcher
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=atsocy-api
Group=atsocy-api
WorkingDirectory=/srv/atsocy.com
EnvironmentFile=/etc/atsocy/prices.env
ExecStart=/usr/bin/npm run fetch:prices
NoNewPrivileges=yes
PrivateTmp=yes
ProtectSystem=strict
ProtectHome=yes
ReadWritePaths=/var/www/atsocy-api
