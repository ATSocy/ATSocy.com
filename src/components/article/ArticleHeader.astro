---
import HeroImage from '~/components/article/HeroImage.astro';
import type { HeroImage as HeroImageValue } from '~/lib/articles/hero-images';

export interface Props {
  title: string;
  description: string;
  heroImage?: HeroImageValue;
  heroImageAlt?: string;
}

const { title, description, heroImage, heroImageAlt } = Astro.props;
---

<header class="mb-10">
  <h1 class="xnn-article-title">
    {title}
  </h1>
  {description && (
    <p class="mt-4 max-w-prose xnn-dek">
      {description}
    </p>
  )}
  {heroImage && (
    <HeroImage
      image={heroImage}
      alt={heroImageAlt}
      widths={[800, 1200, 1600]}
      sizes="(max-width: 1024px) 100vw, 1150px"
      frameClass="relative left-1/2 mt-8 w-[115%] max-w-none -translate-x-1/2 border border-line"
      class="block h-auto w-full"
    />
  )}
</header>
