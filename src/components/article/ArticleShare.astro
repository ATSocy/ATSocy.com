---
import { NostrIcon } from '~/components/icons/NostrIcon';

export interface Props {
  title: string;
  url: string;
  nostrEventId?: string;
}

const { title, url, nostrEventId } = Astro.props;
const nostrValue = nostrEventId ? `nostr:${nostrEventId}` : url;
---

<div class="relative" data-share-root data-share-url={url} data-share-title={title} data-share-nostr={nostrValue}>
  <button
    type="button"
    class="xnn-icon-button h-11 w-11 rounded-full bg-raised hover:bg-line"
    aria-expanded="false"
    aria-label="Share this article"
    data-share-trigger
  >
    <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
      <circle cx="4" cy="9" r="2" fill="currentColor"></circle>
      <circle cx="13.5" cy="4" r="2" fill="currentColor"></circle>
      <circle cx="13.5" cy="14" r="2" fill="currentColor"></circle>
      <path d="M5.8 8 11.8 4.9M5.8 10 11.8 13.1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
    </svg>
  </button>

  <div class="pointer-events-none absolute right-0 top-14 flex flex-col items-end gap-2 opacity-0" hidden data-share-panel>
    <button
      type="button"
      class="xnn-icon-button h-10 w-10 rounded-full bg-canvas shadow-sm ring-1 ring-line"
      aria-label="Copy Nostr share"
      data-share-action="nostr"
    >
      <NostrIcon className="h-4 w-4" />
    </button>
    <button
      type="button"
      class="xnn-icon-button h-10 w-10 rounded-full bg-canvas shadow-sm ring-1 ring-line"
      aria-label="Copy article link"
      data-share-action="link"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M10.46 13.54a3.25 3.25 0 0 0 4.6 0l2.12-2.12a3.25 3.25 0 0 0-4.6-4.6l-.53.53" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
        <path d="M13.54 10.46a3.25 3.25 0 0 0-4.6 0l-2.12 2.12a3.25 3.25 0 0 0 4.6 4.6l.53-.53" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
      </svg>
    </button>
  </div>
</div>

<script>
  import { gsap } from 'gsap';

  const CHECKMARK_SVG = '<svg width="16" height="16" viewBox="0 0 12 12" fill="none" class="text-accent" aria-hidden="true"><path fill="currentColor" fill-rule="evenodd" d="M9.53 3.22a.75.75 0 0 1 0 1.06l-4.5 4.5a.75.75 0 0 1-1.06 0l-1.5-1.5a.75.75 0 0 1 1.06-1.06l.97.97l3.97-3.97a.75.75 0 0 1 1.06 0" clip-rule="evenodd"></path></svg>';

  const roots = document.querySelectorAll<HTMLElement>('[data-share-root]');

  for (const root of roots) {
    const trigger = root.querySelector<HTMLButtonElement>('[data-share-trigger]');
    const panel = root.querySelector<HTMLElement>('[data-share-panel]');
    const options = panel ? Array.from(panel.querySelectorAll<HTMLElement>('[data-share-action]')) : [];

    if (!trigger || !panel || options.length === 0) continue;

    let open = false;

    // Store original icon HTML for restoration.
    const originals = new Map<HTMLElement, string>();
    for (const btn of options) {
      originals.set(btn, btn.innerHTML);
    }

    const restoreIcons = () => {
      for (const btn of options) {
        const saved = originals.get(btn);
        if (saved !== undefined) btn.innerHTML = saved;
      }
    };

    const show = () => {
      restoreIcons();
      open = true;
      trigger.setAttribute('aria-expanded', 'true');
      panel.hidden = false;
      panel.classList.remove('pointer-events-none');
      gsap.fromTo(
        options,
        { opacity: 0, y: -10, scale: 0.7, rotate: -12 },
        { opacity: 1, y: 0, scale: 1, rotate: 0, duration: 0.35, stagger: 0.06, ease: 'back.out(1.8)' }
      );
      gsap.to(panel, { opacity: 1, duration: 0.2, ease: 'power2.out' });
    };

    const hide = () => {
      if (!open) return;
      open = false;
      trigger.setAttribute('aria-expanded', 'false');
      gsap.to(options, {
        opacity: 0,
        y: -8,
        scale: 0.8,
        duration: 0.18,
        stagger: 0.03,
        ease: 'power2.in',
        onComplete: () => {
          restoreIcons();
          panel.hidden = true;
          panel.classList.add('pointer-events-none');
        },
      });
      gsap.to(panel, { opacity: 0, duration: 0.18, ease: 'power2.in' });
    };

    trigger.addEventListener('click', () => {
      if (open) {
        hide();
        return;
      }

      roots.forEach((otherRoot) => {
        if (otherRoot !== root) {
          otherRoot.querySelector<HTMLButtonElement>('[data-share-trigger]')?.setAttribute('aria-expanded', 'false');
          const otherPanel = otherRoot.querySelector<HTMLElement>('[data-share-panel]');
          otherPanel?.classList.add('pointer-events-none');
          if (otherPanel) {
            otherPanel.hidden = true;
            gsap.set(otherPanel, { opacity: 0 });
          }
        }
      });

      show();
    });

    root.addEventListener('click', async (event) => {
      const target = event.target;

      if (!(target instanceof Element)) return;

      const clickedBtn = target.closest<HTMLElement>('[data-share-action]');
      const action = clickedBtn?.dataset.shareAction;
      if (!action || !clickedBtn) return;

      const value = action === 'nostr' ? root.dataset.shareNostr : root.dataset.shareUrl;
      if (!value) return;

      try {
        await navigator.clipboard.writeText(value);
      } catch {
        /* clipboard may be unavailable */
      }

      // Morph the clicked button's icon into a checkmark, hold, then hide.
      clickedBtn.innerHTML = CHECKMARK_SVG;
      gsap.set(clickedBtn, { scale: 0 });
      gsap.to(clickedBtn, { scale: 1, duration: 0.25, ease: 'back.out(2)' });

      // Dim the other (non-clicked) buttons.
      for (const btn of options) {
        if (btn !== clickedBtn) {
          gsap.to(btn, { opacity: 0.3, duration: 0.2 });
        }
      }

      setTimeout(() => hide(), 2000);
    });

    document.addEventListener('click', (event) => {
      if (!root.contains(event.target as Node)) hide();
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') hide();
    });
  }
</script>
