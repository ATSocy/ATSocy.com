---
import { ArticleCommentCount } from '~/components/article/ArticleCommentCount';

export interface Props {
  title: string;
  pubDate: Date;
  readingTimeMinutes: number;
  tag?: string;
  slug?: string;
  showCommentCount?: boolean;
}

const { title, pubDate, readingTimeMinutes, tag, slug, showCommentCount = true } = Astro.props;

const dateFormatter = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<section data-reading-progress>
  <div class="space-y-3">
    <p class="max-w-60 xnn-copy-sm font-semibold">{title}</p>
    <p class="xnn-meta">{dateFormatter.format(pubDate)}</p>
    {tag && (
      <p class="xnn-meta">
        <span class="inline-flex items-center gap-1.5 text-fg-subtle">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true" class="shrink-0 overflow-visible">
            <g fill="currentColor" fill-rule="evenodd" clip-rule="evenodd">
              <path d="M11.216 6.282a.75.75 0 0 1 .502.934l-.61 2.034h3.434l.74-2.466a.75.75 0 0 1 1.436.432l-.61 2.034H18a.75.75 0 0 1 0 1.5h-2.342l-.75 2.5H17a.75.75 0 0 1 0 1.5h-2.542l-.74 2.465a.75.75 0 0 1-1.436-.43l.61-2.035H9.458l-.74 2.465a.75.75 0 1 1-1.436-.43l.61-2.035H6a.75.75 0 0 1 0-1.5h2.342l.75-2.5H7a.75.75 0 0 1 0-1.5h2.542l.74-2.466a.75.75 0 0 1 .934-.502m-.558 4.468h3.434l-.75 2.5H9.908z"></path>
              <path d="M11.943 1.25c-2.309 0-4.118 0-5.53.19c-1.444.194-2.584.6-3.479 1.494c-.895.895-1.3 2.035-1.494 3.48c-.19 1.411-.19 3.22-.19 5.529v.114c0 2.309 0 4.118.19 5.53c.194 1.444.6 2.584 1.494 3.479c.895.895 2.035 1.3 3.48 1.494c1.411.19 3.22.19 5.529.19h.114c2.309 0 4.118 0 5.53-.19c1.444-.194 2.584-.6 3.479-1.494c.895-.895 1.3-2.035 1.494-3.48c.19-1.411.19-3.22.19-5.529v-.114c0-2.309 0-4.118-.19-5.53c-.194-1.444-.6-2.584-1.494-3.479c-.895-.895-2.035-1.3-3.48-1.494c-1.411-.19-3.22-.19-5.529-.19zM3.995 3.995c.57-.57 1.34-.897 2.619-1.069c1.3-.174 3.008-.176 5.386-.176s4.086.002 5.386.176c1.279.172 2.05.5 2.62 1.069c.569.57.896 1.34 1.068 2.619c.174 1.3.176 3.008.176 5.386s-.002 4.086-.176 5.386c-.172 1.279-.5 2.05-1.069 2.62c-.57.569-1.34.896-2.619 1.068c-1.3.174-3.008.176-5.386.176s-4.086-.002-5.386-.176c-1.279-.172-2.05-.5-2.62-1.069c-.569-.57-.896-1.34-1.068-2.619c-.174-1.3-.176-3.008-.176-5.386s.002-4.086.176-5.386c.172-1.279.5-2.05 1.069-2.62"></path>
            </g>
          </svg>
          <span>{tag}</span>
        </span>
      </p>
    )}
    {slug && showCommentCount && (
      <p class="xnn-meta">
        <ArticleCommentCount client:visible slug={slug} href="#comments" />
      </p>
    )}
    <p class="flex items-center gap-1.5 xnn-meta">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true" class="shrink-0 overflow-visible">
        <path d="M7 4.75h10a1.25 1.25 0 0 1 1.25 1.25v11.75H8.75A1.75 1.75 0 0 0 7 19.5V4.75Zm0 0H6A1.25 1.25 0 0 0 4.75 6v11.25A2.25 2.25 0 0 0 7 19.5h11.25" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"></path>
        <path d="M9.75 8.5h5.5M9.75 11.5h5.5M9.75 14.5h3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
      </svg>
      <span><span class="xnn-mono">{readingTimeMinutes}</span> min</span>
    </p>
  </div>

  <div class="mt-3">
    <div class="h-1 overflow-hidden bg-raised">
      <div class="h-full origin-left scale-x-0 bg-accent" data-reading-progress-fill></div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const article = document.querySelector<HTMLElement>('[data-article-body]');

  if (article) {
    document.querySelectorAll<HTMLElement>('[data-reading-progress-fill]').forEach((fill) => {
      gsap.set(fill, { transformOrigin: 'left center', scaleX: 0 });

      ScrollTrigger.create({
        trigger: article,
        start: 'top top+=96',
        end: 'bottom bottom-=96',
        invalidateOnRefresh: true,
        onUpdate: (self) => {
          gsap.set(fill, { scaleX: self.progress });
        },
      });
    });
  }
</script>
