---
/**
 * EditorialCard — one editorial item. Two structural variants mirror decrypt's
 * hero pattern: `lead` (large, with media) and `compact` (headline + dek).
 * Pure static HTML; no client JS.
 */
import { ArticleCommentCount } from '~/components/article/ArticleCommentCount';
import HeroImage from '~/components/article/HeroImage.astro';
import { articleHref, allowsComments, nostrDocumentId, type ArticleEntry } from '~/lib/articles/posts';
import TechDivider from '~/components/xenon/TechDivider.astro';

export interface Props {
  post: ArticleEntry;
  variant?: 'lead' | 'compact';
  showTags?: boolean;
  showDivider?: boolean;
  dividerVariant?: 'shelf' | 'stripes' | 'dots';
}

const { post, variant = 'compact', showTags = true, showDivider = false, dividerVariant = 'shelf' } = Astro.props;
const { title, description, pubDate, tags, heroImage, heroImageAlt } = post.data;
const href = articleHref(post);
const commentSlug = nostrDocumentId(post);
const date = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

{variant === 'lead' ? (
  <article class="group">
    {heroImage && (
      <a href={href} class="block overflow-hidden rounded-card border border-line" aria-hidden="true" tabindex="-1">
        <HeroImage
          image={heroImage}
          alt={heroImageAlt}
          widths={[640, 960, 1280]}
          sizes="(max-width: 1024px) 100vw, 960px"
          loading="lazy"
          class="aspect-[16/9] w-full object-cover"
        />
      </a>
    )}
    <div class={heroImage ? 'mt-4' : ''}>
      {showTags && tags.length > 0 && (
        <p class="xnn-label font-normal uppercase">
          {tags.slice(0, 1).join('')}
        </p>
      )}
      <h3 class="mt-1 xnn-editorial-title-lg">
        <a href={href} class="xnn-title-link">{title}</a>
      </h3>
      <p class="mt-2 max-w-prose xnn-body">{description}</p>
      <p class="mt-3 flex flex-wrap items-center gap-x-3 gap-y-1 xnn-meta">
        <span>{date}</span>
        {allowsComments(post) && <ArticleCommentCount client:visible slug={commentSlug} href={`${href}#comments`} />}
      </p>
    </div>
  </article>
) : (
  <article class="py-5 first:pt-0">
    {showDivider && <TechDivider variant={dividerVariant} class="mb-5" />}
    <a href={href} class="group block no-underline">
      {showTags && tags.length > 0 && (
        <p class="xnn-label font-normal uppercase">
          {tags.slice(0, 1).join('')}
        </p>
      )}
      <h3 class="mt-1 xnn-editorial-title-sm">
        <span class="xnn-title-link transition-colors group-hover:text-accent">{title}</span>
      </h3>
      <p class="mt-1 xnn-body-sm">{description}</p>
      <div class="mt-2 flex flex-wrap items-center gap-x-3 gap-y-1 xnn-meta">
        <span>{date}</span>
        {allowsComments(post) && <ArticleCommentCount client:visible slug={commentSlug} href={`${href}#comments`} />}
      </div>
    </a>
  </article>
)}
