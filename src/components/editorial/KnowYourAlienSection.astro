---
import type { CollectionEntry } from 'astro:content';
import { heroImageSrc } from '~/lib/articles/hero-images';
import { articleHref } from '~/lib/articles/posts';

export interface Props {
  posts: CollectionEntry<'kya'>[];
}

const { posts } = Astro.props;

const contributorMeta: Record<string, { name: string; role: string; avatar: string }> = {
  sugoi: {
    name: 'Sugoi',
    role: 'Zitadel Logz',
    avatar: '/images/kya/sugoi.jpg',
  },
  'stark-of-zenon': {
    name: 'Stark of Zenon',
    role: 'zenon.tv',
    avatar: '/images/kya/Stark_of_Zenon.jpg',
  },
};

const interviews = [...posts]
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .map((post) => {
    const fallbackName = post.data.title.replace(/^Know Your Alien:\s*/i, '').trim();
    const meta = contributorMeta[post.id];

    return {
      href: articleHref(post),
      title: post.data.title,
      date: post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }),
      description: post.data.description,
      name: meta?.name ?? fallbackName,
      role: meta?.role ?? post.data.description,
      avatar: meta?.avatar ?? heroImageSrc(post.data.heroImage) ?? '/images/kya/question-icon.png',
    };
  });

const placeholders = Math.max(0, 4 - interviews.length);
---

{interviews.length > 0 && (
  <section class="mt-10 border-t border-line/30 pt-10" aria-label="Know Your Alien">
    <h2 class="xnn-heading-xl text-fg">Know Your Alien</h2>

    <p class="mt-4 max-w-prose xnn-body-sm">
      The aliens know, but do you know the aliens? Join us for a series of interviews with the people building the
      Zenon Network.
    </p>

    <div class="mt-6 flex gap-6 overflow-x-auto pb-2">
      <div class="contents lg:hidden">
        {interviews.map((interview) => (
          <a href={interview.href} class="group flex min-w-[7rem] shrink-0 flex-col items-center text-center no-underline" aria-label={interview.title}>
            <span class="xnn-caption uppercase text-fg-subtle">Community</span>
            <span class="mt-3 flex h-20 w-20 overflow-hidden rounded-full border border-line-strong bg-surface-2 transition-colors group-hover:border-accent">
              <img src={interview.avatar} alt={interview.name} class="h-full w-full object-cover" loading="lazy" />
            </span>
            <span class="mt-3 xnn-copy-sm font-semibold text-fg transition-colors group-hover:text-accent">{interview.name}</span>
            <span class="mt-1 xnn-meta">{interview.role}</span>
          </a>
        ))}

        {Array.from({ length: placeholders }).map(() => (
          <div class="flex min-w-[7rem] shrink-0 flex-col items-center text-center opacity-40" aria-hidden="true">
            <span class="mt-3 flex h-20 w-20 items-center justify-center rounded-full border border-line bg-surface-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 36 36" aria-hidden="true" class="shrink-0 overflow-visible">
                <path fill="#ccd6dd" d="M17 27a3 3 0 0 1-3-3v-4a3 3 0 0 1 3-3c.603-.006 6-1 6-5c0-2-2-4-5-4c-2.441 0-4 2-4 3a3 3 0 1 1-6 0c0-4.878 4.58-9 10-9c8 0 11 5.982 11 11c0 4.145-2.277 7.313-6.413 8.92c-.9.351-1.79.587-2.587.747V24a3 3 0 0 1-3 3"></path>
                <circle cx="17" cy="32" r="3" fill="#ccd6dd"></circle>
              </svg>
            </span>
          </div>
        ))}
      </div>

      <div class="hidden w-full grid-cols-4 gap-6 lg:grid">
        {interviews.map((interview) => (
          <a href={interview.href} class="group flex flex-col items-center text-center no-underline" aria-label={interview.title}>
            <span class="xnn-caption uppercase text-fg-subtle">Community</span>
            <span class="mt-3 flex h-20 w-20 overflow-hidden rounded-full border border-line-strong bg-surface-2 transition-colors group-hover:border-accent">
              <img src={interview.avatar} alt={interview.name} class="h-full w-full object-cover" loading="lazy" />
            </span>
            <span class="mt-3 xnn-copy-sm font-semibold text-fg transition-colors group-hover:text-accent">{interview.name}</span>
            <span class="mt-1 xnn-meta">{interview.role}</span>
          </a>
        ))}

        {Array.from({ length: placeholders }).map(() => (
          <div class="flex flex-col items-center text-center opacity-40" aria-hidden="true">
            <span class="mt-3 flex h-20 w-20 items-center justify-center rounded-full border border-line bg-surface-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 36 36" aria-hidden="true" class="shrink-0 overflow-visible">
                <path fill="#ccd6dd" d="M17 27a3 3 0 0 1-3-3v-4a3 3 0 0 1 3-3c.603-.006 6-1 6-5c0-2-2-4-5-4c-2.441 0-4 2-4 3a3 3 0 1 1-6 0c0-4.878 4.58-9 10-9c8 0 11 5.982 11 11c0 4.145-2.277 7.313-6.413 8.92c-.9.351-1.79.587-2.587.747V24a3 3 0 0 1-3 3"></path>
                <circle cx="17" cy="32" r="3" fill="#ccd6dd"></circle>
              </svg>
            </span>
          </div>
        ))}
      </div>
    </div>
  </section>
)}
