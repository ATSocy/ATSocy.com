---
import Layout from '~/layouts/Layout.astro';
---

<Layout title="Not found" description="The requested page could not be found." noindex>
  <div class="xnn-container-page">
    <section class="mx-auto flex max-w-3xl flex-col items-center px-4 py-16 text-center sm:py-20">
      <img src="/atsocy-404.png" alt="ATSocy 404" class="h-80" />
      <p class="mt-8 xnn-body-lg">What does this thing do?</p>
      <a
        href="/"
        class="mt-8 inline-flex items-center justify-center rounded-[24px] corner-squircle bg-accent px-5 py-3 text-body-sm font-medium text-on-accent no-underline transition-colors hover:text-on-accent"
      >
        Take me back
      </a>
    </section>
  </div>
</Layout>
