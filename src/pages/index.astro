---
import { getCollection } from 'astro:content';
import Layout from '~/layouts/Layout.astro';
import EditorialHero from '~/components/editorial/EditorialHero.astro';
import KnowYourAlienSection from '~/components/editorial/KnowYourAlienSection.astro';
import { DevActivityRail } from '~/components/rails/DevActivityRail';
import { ChannelsRail } from '~/components/rails/ChannelsRail';
import { PulseHot, Pulse } from '~/components/pulse/Pulse';
import TechDivider from '~/components/xenon/TechDivider.astro';
import { AlienPulseCta } from '~/components/editorial/AlienPulseCta';
import { AiBadgeIcon } from '~/components/icons/AiBadgeIcon';
import { HOT_PULSE_WINDOW_HOURS } from '~/config/feeds';

function formatPulseWindow(hours: number): string {
  if (hours % 24 === 0) {
    const days = hours / 24;
    return `Showing posts from the last ${days} ${days === 1 ? 'day' : 'days'}`;
  }

  return `Showing posts from the last ${hours} ${hours === 1 ? 'hour' : 'hours'}`;
}

const pulseWindowLabel = formatPulseWindow(HOT_PULSE_WINDOW_HOURS);

const newsPosts = (await getCollection('news', (post) => !post.data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
const [lead, ...rest] = newsPosts;
const highlights = rest.slice(0, 4);
const knowYourAlienPosts = (await getCollection('kya', (post) => !post.data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
---

<Layout>
  <div class="xnn-container-page -mt-8">
    <section class="xnn-panel border-t-0">
      <div class="xnn-grid xnn-grid--flush border-b border-line/30">
        <aside id="dev-activity" aria-label="Dev Activity" class="order-3 xnn-col-span-full border-b border-line/30 px-4 py-8 lg:order-none lg:xnn-col-span-3 lg:border-b-0 lg:border-r lg:border-line/40 lg:px-4 lg:py-10 scroll-mt-32">
          <header class="mb-6 lg:px-4">
            <h2 class="xnn-heading-sm">Dev Activity</h2>
          </header>
          <DevActivityRail client:load />
        </aside>

        <section aria-label="News" class="order-1 xnn-col-span-full border-b border-line/30 px-4 pb-8 pt-2 lg:order-none lg:xnn-col-span-6 lg:border-b-0 lg:px-8 lg:pb-10 lg:pt-4">
          <section aria-label="Post of the day" class="mb-8">
            <header class="flex justify-center">
              <img src="/atsocy-potd.png" alt="ATSocy Post of the Day" class="w-48 max-w-full" />
            </header>
            <PulseHot client:load limit={1} windowHours={HOT_PULSE_WINDOW_HOURS} />
            <div class="flex justify-center">
              <a
                href="#pulse"
                data-potd-view-all
                class="xnn-meta text-accent no-underline hover:underline"
              >
                View all
              </a>
            </div>
            <TechDivider variant="dots" class="mt-8" />
          </section>
          {lead && <EditorialHero lead={lead} highlights={highlights} />}
          <div class="mt-6">
            <a href="/news" class="xnn-button-secondary inline-flex w-full items-center justify-center px-4 py-3 xnn-heading-sm no-underline">
              Browse all
            </a>
          </div>
          <KnowYourAlienSection posts={knowYourAlienPosts} />
        </section>

        <aside id="channels" aria-label="Channels" class="order-2 xnn-col-span-full px-4 py-8 lg:order-none lg:xnn-col-span-3 lg:border-l lg:border-line/40 lg:px-8 lg:py-10 scroll-mt-32">
          <header class="mb-6 flex items-center justify-between gap-4">
            <h2 class="xnn-heading-sm">Channels</h2>
            <span class="inline-flex items-center gap-1.5 xnn-meta">
              <AiBadgeIcon />
              <span>Generated by AI</span>
            </span>
          </header>
          <div class="relative">
            <ChannelsRail client:visible />
            <div aria-hidden="true" class="pointer-events-none absolute inset-0 z-10 flex items-center justify-center px-4">
              <img
                src="/atsocy-zoon.png"
                alt=""
                class="w-[min(16rem,72%)] max-w-none drop-shadow-[0_16px_36px_rgba(15,23,42,0.22)]"
              />
            </div>
          </div>
        </aside>
      </div>
    </section>
  </div>

  <section id="pulse" aria-label="Pulse" class="scroll-mt-32">
    <div class="xnn-container-page -mt-px">
      <div class="xnn-panel overflow-visible border-b-0">
          <header class="relative z-10 flex flex-col items-center gap-5 overflow-visible px-6 py-8 sm:flex-row sm:justify-between sm:px-8 lg:px-10 lg:py-8">
            <img src="/atsocy-pulse.png" alt="ATSocy Pulse" class="w-[20rem] mx-auto sm:mx-0" />
            <p class="xnn-meta text-center text-fg-muted sm:flex-1 sm:px-6">{pulseWindowLabel}</p>
            <AlienPulseCta client:visible href="/create-post" />
          </header>
         <Pulse client:load windowHours={HOT_PULSE_WINDOW_HOURS} />
       </div>
     </div>
   </section>

  <script>
    import gsap from 'gsap';
    import { ScrollToPlugin } from 'gsap/ScrollToPlugin';

    gsap.registerPlugin(ScrollToPlugin);

    function initScrollHandler() {
      const trigger = document.querySelector('[data-potd-view-all]');
      const pulseSection = document.querySelector('#pulse');

      if (trigger instanceof HTMLAnchorElement && pulseSection instanceof HTMLElement) {
        trigger.addEventListener('click', (event) => {
          if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

          event.preventDefault();

          const stickyHeader = document.querySelector('body > div.sticky');
          const offsetY =
            (stickyHeader instanceof HTMLElement ? stickyHeader.offsetHeight : 0) + 40;

          gsap.to(window, {
            duration: 0.45,
            ease: 'power3.out',
            overwrite: 'auto',
            scrollTo: {
              y: pulseSection,
              offsetY,
            },
          });
        });
      }
    }

    initScrollHandler();
  </script>
</Layout>
